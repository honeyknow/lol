# =============================================================
# ISHA-X EDR — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Quick start:
#   cp .env.example .env
#   nano .env     (fill in GROQ_API_KEY, ADMIN_EMAILS, SESSION_SECRET, TAILSCALE_AUTH_KEY)
#   bash setup.sh
#   bash start.sh
# =============================================================

# -----------------------------------------------------------
# AI Assistant (Groq API — free at console.groq.com)
# -----------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_api_key_here

# -----------------------------------------------------------
# Access Control
# First email = admin (can manage users/tenants)
# -----------------------------------------------------------
ADMIN_EMAILS=your@gmail.com
ADMIN_PASSWORD=admin

# -----------------------------------------------------------
# Session Security
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------
SESSION_SECRET=change-me-to-a-random-hex-string

# -----------------------------------------------------------
# Tailscale VPN
# Get an auth key from: https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key for Codespaces
# -----------------------------------------------------------
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# Server Host (auto-set by start.sh from Tailscale IP)
# You can also use a custom domain pointing to your Tailscale IP
# -----------------------------------------------------------
SERVER_HOST=100.x.x.x

# -----------------------------------------------------------
# Wazuh Manager API
# These match the credentials in server/wazuh/docker-compose.yml
# DO NOT change unless you change them in docker-compose.yml too
# -----------------------------------------------------------
WAZUH_API_BASE=https://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=MyS3cr37P450r.*-

# -----------------------------------------------------------
# Multi-tenant mode (always 1 for SaaS operation)
# -----------------------------------------------------------
MULTI_TENANT=1

# -----------------------------------------------------------
# Ingestor settings (auto-detected by ingestor.py — no need to change)
# -----------------------------------------------------------
ARCHIVES_JSON=/tmp/wazuh_logs/archives/archives.json
POLL_INTERVAL=0.5
EDR_RETENTION_DAYS=30
